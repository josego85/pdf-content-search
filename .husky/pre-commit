#!/bin/sh

# Pre-commit: run quality checks if dev containers are up.
# If containers are not running, skip gracefully — CI is the real gate.

DEV_PHP_RUNNING=$(docker compose -f docker-compose.yml -f docker-compose.dev.yml ps --status running --services 2>/dev/null | grep -c "^php$" || true)

if [ "$DEV_PHP_RUNNING" -eq 0 ]; then
  echo "⚠  Dev containers not running — skipping local checks (CI will enforce quality gates)."
  exit 0
fi

echo "🔍 Running PHP-CS-Fixer check..."
if ! docker compose -f docker-compose.yml -f docker-compose.dev.yml exec -T php composer cs-check; then
  echo "❌ Code style violations detected. Run: make cs-fix"
  exit 1
fi
echo "✅ PHP code style is clean."

echo "🔬 Running PHPStan..."
if ! docker compose -f docker-compose.yml -f docker-compose.dev.yml exec -T php composer phpstan; then
  echo "❌ PHPStan found errors. Fix them before committing."
  exit 1
fi
echo "✅ PHPStan passed."

echo "🧪 Running tests..."
if ! docker compose -f docker-compose.yml -f docker-compose.dev.yml exec -T php bash -c "XDEBUG_MODE=coverage php bin/phpunit"; then
  echo "❌ Tests failed. Fix them before committing."
  exit 1
fi
echo "✅ Tests passed."

echo "🎨 Running Biome lint..."
if ! npm run lint --silent; then
  echo "❌ Linting errors detected. Run: npm run lint"
  exit 1
fi
echo "✅ JS/Vue clean."

echo "✨ All checks passed."

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}PDF Content Search — AI-Powered Document Search{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Search and find content within your PDF documents using AI-powered hybrid search with instant highlighting.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{% block canonical %}{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}{% endblock %}">
    <meta property="og:title" content="{% block og_title %}PDF Content Search{% endblock %}">
    <meta property="og:description" content="{% block og_description %}AI-powered PDF document search with intelligent highlighting and instant results.{% endblock %}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    {% block structured_data %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "PDF Content Search",
      "description": "AI-powered PDF document search with hybrid lexical and semantic search.",
      "url": "{{ app.request.schemeAndHttpHost }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ app.request.schemeAndHttpHost }}/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    {% endblock %}
    {% block stylesheets %}{% endblock %}
            {{ encore_entry_link_tags('app') }}
    {% block head_scripts %}{% endblock %}
</head>
<body>
    <a href="#main-content" class="absolute left-0 top-0 z-50 px-4 py-2 bg-blue-600 text-white font-medium -translate-y-full focus:translate-y-0 transition-transform">Skip to main content</a>
    <main id="main-content">
        {% block body %}{% endblock %}
    </main>
    {% block javascripts %}{% endblock %}
            {{ encore_entry_script_tags('app') }}
</body>
</html>
